<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Responsive Image Gallery</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #111;
      color: white;
    }

    h1 {
      text-align: center;
      margin: 20px 0;
    }

    /* Filter Buttons */
    .filters {
      text-align: center;
      margin-bottom: 20px;
    }

    .filters button {
      padding: 10px 20px;
      margin: 5px;
      border: none;
      cursor: pointer;
      background: #444;
      color: white;
      border-radius: 20px;
      transition: 0.3s;
    }

    .filters button:hover {
      background: #ff9800;
    }

    /* Gallery Grid */
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      padding: 20px;
    }

    .gallery-item {
      position: relative;
      overflow: hidden;
      border-radius: 10px;
      cursor: pointer;
    }

    .gallery img {
      width: 100%;
      height: 100%;
      display: block;
      transition: transform 0.4s ease, filter 0.4s ease;
    }

    /* Hover Effect */
    .gallery-item:hover img {
      transform: scale(1.1);
      filter: brightness(70%);
    }

    /* Lightbox */
    .lightbox {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.9);
      display: none;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      z-index: 999;
    }

    .lightbox img {
      max-width: 90%;
      max-height: 80%;
      border-radius: 10px;
    }

    .controls {
      margin-top: 15px;
    }

    .controls button {
      padding: 10px 20px;
      margin: 5px;
      border: none;
      cursor: pointer;
      background: #ff9800;
      color: white;
      border-radius: 5px;
      font-size: 16px;
    }

    .close {
      position: absolute;
      top: 20px;
      right: 30px;
      font-size: 30px;
      cursor: pointer;
      color: white;
    }

    /* Responsive */
    @media(max-width:600px){
      h1{
        font-size: 22px;
      }
    }

  </style>
</head>

<body>

<h1>Responsive Image Gallery</h1>

<div class="filters">
  <button onclick="filterImages('all')">All</button>
  <button onclick="filterImages('cyber crime')">cyber crime</button>
  <button onclick="filterImages('Ai tools')">Ai tools</button>
  <button onclick="filterImages('cars')">Cars</button>
</div>

<div class="gallery">

  

  <div class="gallery-item data visualization">
    <img src="/images/IMG_20240528_125103.jpg">
  </div>

  <div class="gallery-item Ai tools">
    <img src="/images/IMG-20260223-WA0003.jpg">
  </div>

  <div class="gallery-item cyber crime">
    <img src="/images/IMG-20251113-WA0005.jpg">
  </div>

  <div class="gallery-item car">
    <img src="/images/image_655787de.png" >
  </div>

</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <span class="close" onclick="closeLightbox()">✖</span>
  <img id="lightbox-img">
  
  <div class="controls">
    <button onclick="prevImage()">Prev</button>
    <button onclick="nextImage()">Next</button>
  </div>
</div>


<script>

let images = document.querySelectorAll(".gallery img");
let lightbox = document.getElementById("lightbox");
let lightboxImg = document.getElementById("lightbox-img");

let currentIndex = 0;

function openLightbox(index) {
  currentIndex = index;
  lightbox.style.display = "flex";
  lightboxImg.src = images[index].src;
}

function closeLightbox() {
  lightbox.style.display = "none";
}

function nextImage() {
  currentIndex = (currentIndex + 1) % images.length;
  lightboxImg.src = images[currentIndex].src;
}

function prevImage() {
  currentIndex = (currentIndex - 1 + images.length) % images.length;
  lightboxImg.src = images[currentIndex].src;
}

/* Filter Function */
function filterImages(category) {
  let items = document.querySelectorAll(".gallery-item");

  items.forEach(item => {
    if (category === "all") {
      item.style.display = "block";
    } else {
      item.style.display = item.classList.contains(category)
        ? "block"
        : "none";
    }
  });
}

</script>

</body>
</html>
